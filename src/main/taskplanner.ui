   <string notr="true">
/* Основное окно */
QMainWindow {
    background-color: #e8eaf6;
}

/* Кнопки */
QPushButton {
    background-color: #3f51b5;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: bold;
    min-height: 45px;
}

QPushButton:hover {
    background-color: #303f9f;
}

QPushButton:pressed {
    background-color: #1a237e;
}

QPushButton#btnDelete {
    background-color: #e53935;
}

QPushButton#btnDelete:hover {
    background-color: #c62828;
}

QPushButton#btnMarkComplete {
    background-color: #43a047;
}

QPushButton#btnMarkComplete:hover {
    background-color: #2e7d32;
}

/* Поля ввода */
QLineEdit {
    border: 2px solid #c5cae9;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    background-color: #ffffff;
    color: #212121;
}

QLineEdit:focus {
    border: 2px solid #3f51b5;
}

QLineEdit:hover {
    border: 2px solid #9fa8da;
}

/* ComboBox */
QComboBox {
    border: 2px solid #c5cae9;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 14px;
    background-color: #ffffff;
    color: #212121;
    min-width: 180px;
}

QComboBox:focus {
    border: 2px solid #3f51b5;
}

QComboBox:hover {
    border: 2px solid #9fa8da;
}

QComboBox::drop-down {
    border: none;
    padding-right: 10px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #5c6bc0;
    margin-right: 10px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #212121;
    border: 2px solid #c5cae9;
    selection-background-color: #e8eaf6;
}

/* CheckBox */
QCheckBox {
    font-size: 14px;
    spacing: 10px;
    padding: 5px;
    color: #212121;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #9fa8da;
    border-radius: 4px;
    background-color: #ffffff;
}

QCheckBox::indicator:checked {
    background-color: #3f51b5;
    border: 2px solid #3f51b5;
}

QCheckBox::indicator:hover {
    border: 2px solid #3f51b5;
}

/* Labels */
QLabel {
    color: #212121;
    background-color: transparent;
}

/* GroupBox */
QGroupBox {
    font-size: 16px;
    font-weight: bold;
    border: 2px solid #c5cae9;
    border-radius: 10px;
    margin-top: 15px;
    padding-top: 15px;
    background-color: #ffffff;
    color: #212121;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 10px;
    color: #3f51b5;
}

/* Calendar */
QCalendarWidget {
    border: none;
    background-color: #ffffff;
    border-radius: 10px;
}

QCalendarWidget QToolButton {
    background-color: #3f51b5;
    color: #ffffff;
    border: none;
    border-radius: 5px;
    padding: 8px;
    font-weight: bold;
    font-size: 14px;
}

QCalendarWidget QToolButton:hover {
    background-color: #303f9f;
}

QCalendarWidget QMenu {
    background-color: #ffffff;
    border: 1px solid #c5cae9;
    border-radius: 5px;
    color: #212121;
}

QCalendarWidget QWidget {
    alternate-background-color: #f5f5f5;
    color: #212121;
}

QCalendarWidget QAbstractItemView:enabled {
    selection-background-color: #e8eaf6;
    selection-color: #1a237e;
    color: #212121;
}

/* ListWidget */
QListWidget {
    border: 2px solid #c5cae9;
    border-radius: 10px;
    background-color: #ffffff;
    font-size: 14px;
    padding: 5px;
    color: #212121;
}

QListWidget::item {
    padding: 15px;
    border-radius: 8px;
    margin: 3px 0;
    border-bottom: 1px solid #f0f0f0;
    color: #212121;
}

QListWidget::item:hover {
    background-color: #f5f5f5;
}

QListWidget::item:selected {
    background-color: #e8eaf6;
    color: #1a237e;
}

/* ScrollBar */
QScrollBar:vertical {
    background-color: #f5f5f5;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background-color: #bdbdbd;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #9e9e9e;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #f5f5f5;
    height: 12px;
    border-radius: 6px;
}

QScrollBar::handle:horizontal {
    background-color: #bdbdbd;
    border-radius: 6px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #9e9e9e;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* ToolButton */
QToolButton {
    background-color: #3f51b5;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 16px;
    font-weight: bold;
}

QToolButton:hover {
    background-color: #303f9f;
}

/* Frame */
QFrame {
    background-color: #ffffff;
    border-radius: 10px;
}

/* MenuBar */
QMenuBar {
    background-color: #3f51b5;
    color: #ffffff;
}

QMenuBar::item:selected {
    background-color: #303f9f;
}

QMenuBar::item:pressed {
    background-color: #1a237e;
}

/* StatusBar */
QStatusBar {
    background-color: #e8eaf6;
    color: #212121;
}
