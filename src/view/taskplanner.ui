  <property name="styleSheet">
   <string notr="true">
/* Глобальные стили */
QMainWindow {
    background-color: #e8eaf6;
}

QWidget {
    color: #212121;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 13px;
}

/* Кнопки - ЕДИНЫЙ СТИЛЬ */
QPushButton {
    background-color: #ffffff;
    color: #212121;
    border: 1px solid #c5cae9;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: bold;
    min-height: 36px;
    font-size: 13px;
}
QPushButton:hover {
    background-color: #f5f5f5;
    border-color: #9fa8da;
}
QPushButton:pressed {
    background-color: #e8eaf6;
    border-color: #3f51b5;
}

/* Поля ввода */
QLineEdit {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #c5cae9;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
}
QLineEdit:focus {
    border: 2px solid #3f51b5;
}

QTextEdit {
    background-color: #ffffff;
    color: #000000;
    border: 2px solid #9fa8da;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
}
QTextEdit:focus {
    border: 2px solid #3f51b5;
}

/* ComboBox */
QComboBox {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #c5cae9;
    border-radius: 6px;
    padding: 6px 10px;
    min-width: 100px;
    font-size: 13px;
}
QComboBox:hover {
    border: 1px solid #9fa8da;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #000000;
    selection-background-color: #e8eaf6;
    border: 1px solid #c5cae9;
}

/* CheckBox */
QCheckBox {
    color: #000000;
    spacing: 8px;
    font-size: 13px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 2px solid #9fa8da;
    border-radius: 3px;
    background-color: #ffffff;
}
QCheckBox::indicator:checked {
    background-color: #3f51b5;
    border-color: #3f51b5;
}

/* Label */
QLabel {
    color: #000000;
    background-color: transparent;
    font-size: 13px;
}

/* Calendar - исправленная навигация и заголовки */
QCalendarWidget {
    background-color: #ffffff;
    border: 1px solid #c5cae9;
    border-radius: 8px;
}
QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #3f51b5;
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
}
QCalendarWidget QToolButton {
    background-color: transparent;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    font-weight: bold;
    font-size: 13px;
}
QCalendarWidget QToolButton:hover {
    background-color: rgba(255,255,255,0.2);
}
QCalendarWidget QComboBox {
    background-color: transparent;
    color: #ffffff;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 4px;
    padding: 2px 6px;
}
QCalendarWidget QComboBox::drop-down {
    border: none;
    width: 16px;
}
QCalendarWidget QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #000000;
}
QCalendarWidget QHeaderView {
    background-color: #e8eaf6;
    color: #212121;
    font-weight: bold;
    border: none;
}
QCalendarWidget QTableView {
    border: none;
    gridline-color: #e0e0e0;
    background-color: #ffffff;
    selection-background-color: #e8eaf6;
    selection-color: #1a237e;
}

/* Список задач - УЛУЧШЕННЫЕ КАРТОЧКИ */
QListWidget {
    background-color: #f5f5f5;
    border: 1px solid #c5cae9;
    border-radius: 8px;
    padding: 8px;
}
QListWidget::item {
    background-color: #ffffff;
    border: 1px solid #c5cae9;
    border-radius: 6px;
    padding: 10px 12px;
    margin: 4px 0;
}
QListWidget::item:hover {
    background-color: #f8f9fa;
    border-color: #9fa8da;
}
QListWidget::item:selected {
    background-color: #e8eaf6;
    border-color: #3f51b5;
    color: #1a237e;
}

/* GroupBox */
QGroupBox {
    border: 1px solid #c5cae9;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 12px;
    background-color: #ffffff;
    font-weight: bold;
    color: #3f51b5;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #3f51b5;
}

/* Статус */
QLabel#labelStatus {
    padding: 8px;
    border-radius: 6px;
    font-weight: bold;
}

/* ScrollBar */
QScrollBar:vertical {
    background-color: #f5f5f5;
    width: 10px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background-color: #bdbdbd;
    border-radius: 5px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background-color: #9e9e9e;
}

/* DateTimeEdit */
QDateTimeEdit {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #c5cae9;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
}
QDateTimeEdit::drop-down {
    border: none;
    width: 20px;
}
QDateTimeEdit::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #3f51b5;
    margin-right: 10px;
}
